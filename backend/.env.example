# Server Configuration
NODE_ENV=development
PORT=3001

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Encryption (Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-256-bit-encryption-key-in-hex-format

# Email Service (Resend)
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_FROM_EMAIL=romejim@gmail.com

# Application
DEFAULT_USER_ID=your-default-user-id-for-mvp

# Puppeteer Configuration
PUPPETEER_HEADLESS=true
PUPPETEER_TIMEOUT=30000

# Optional: Logging
LOG_LEVEL=info
